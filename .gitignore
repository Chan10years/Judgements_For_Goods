# Python cache files
__pycache__/
**/__pycache__/
*.pyc
*.py[cod]
*.pyo
*$py.class

# Test and tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.env
.venv/
venv/
env/
ENV/

# Runtime logs
logs/*
!logs/.gitkeep
*.log

# Runtime output artifacts
outputs/*.json
outputs/*.docx
outputs/stage8_test_workspace/
outputs/*
!outputs/.gitkeep
